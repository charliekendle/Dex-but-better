--[[
	Secret Service Panel
	Executor + Console Output Viewer
]]

local Main,Lib,Apps,Settings
local Explorer, Properties, ScriptViewer, Notebook
local API,RMD,env,service,plr,create,createSimple

local function initDeps(data)
	Main = data.Main
	Lib = data.Lib
	Apps = data.Apps
	Settings = data.Settings
	API = data.API
	RMD = data.RMD
	env = data.env
	service = data.service
	plr = data.plr
	create = data.create
	createSimple = data.createSimple
end

local function initAfterMain()
	Explorer = Apps.Explorer
	Properties = Apps.Properties
	ScriptViewer = Apps.ScriptViewer
	Notebook = Apps.Notebook
end

local function main()
	local SecretService = {}
	local window, executorFrame, consoleFrame
	local consoleLogs = {}
	local consoleList

	local function addLog(typ, msg)
		local colors = {
			print = Color3.fromRGB(200,200,200),
			warn = Color3.fromRGB(255,200,0),
			error = Color3.fromRGB(255,80,80),
			info = Color3.fromRGB(100,180,255),
		}

		local entry = createSimple("TextLabel", {
			BackgroundTransparency = 1,
			Font = Enum.Font.Code,
			Text = msg,
			TextColor3 = colors[typ] or colors.print,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextWrapped = true,
			Size = UDim2.new(1,-4,0,0),
			AutomaticSize = Enum.AutomaticSize.Y,
			Parent = consoleList,
		})

		table.insert(consoleLogs, entry)

		-- Auto scroll to bottom
		local canvas = consoleList.Parent
		canvas.CanvasPosition = Vector2.new(0, canvas.AbsoluteCanvasSize.Y)
	end

	local function hookOutput()
		local oldPrint = print
		local oldWarn = warn
		local oldError = error

		print = function(...)
			local args = {...}
			local msg = ""
			for i,v in ipairs(args) do
				msg = msg .. tostring(v) .. (i < #args and "\t" or "")
			end
			addLog("print", msg)
			return oldPrint(...)
		end

		warn = function(...)
			local args = {...}
			local msg = ""
			for i,v in ipairs(args) do
				msg = msg .. tostring(v) .. (i < #args and "\t" or "")
			end
			addLog("warn", msg)
			return oldWarn(...)
		end
	end

	SecretService.Init = function()
		window = Lib.Window.new()
		window:SetTitle("Secret Service Panel")
		window:Resize(400,220)
		SecretService.Window = window

		-- Tab bar
		local tabBar = createSimple("Frame", {
			BackgroundColor3 = Color3.fromRGB(25,25,25),
			BorderSizePixel = 0,
			Size = UDim2.new(1,0,0,20),
			Parent = window.GuiElems.Content,
		})

		local executorTabBtn = createSimple("TextButton", {
			BackgroundColor3 = Color3.fromRGB(40,40,40),
			BorderSizePixel = 0,
			Font = Enum.Font.SourceSans,
			Size = UDim2.new(0,100,1,0),
			Text = "Executor",
			TextColor3 = Color3.new(1,1,1),
			TextSize = 14,
			Parent = tabBar,
		})

		local consoleTabBtn = createSimple("TextButton", {
			BackgroundColor3 = Color3.fromRGB(60,60,60),
			BorderSizePixel = 0,
			Font = Enum.Font.SourceSans,
			Position = UDim2.new(0,100,0,0),
			Size = UDim2.new(0,100,1,0),
			Text = "Console",
			TextColor3 = Color3.fromRGB(180,180,180),
			TextSize = 14,
			Parent = tabBar,
		})

		-- Executor frame
		executorFrame = createSimple("Frame", {
			BackgroundColor3 = Color3.fromRGB(30,30,30),
			BorderSizePixel = 0,
			Position = UDim2.new(0,0,0,20),
			Size = UDim2.new(1,0,1,-20),
			Parent = window.GuiElems.Content,
		})

		local codeFrame = Lib.CodeFrame.new()
		codeFrame.Frame.Position = UDim2.new(0,0,0,0)
		codeFrame.Frame.Size = UDim2.new(1,0,1,-24)
		codeFrame.Frame.Parent = executorFrame

		local btnBar = createSimple("Frame", {
			BackgroundColor3 = Color3.fromRGB(25,25,25),
			BorderSizePixel = 0,
			Position = UDim2.new(0,0,1,-24),
			Size = UDim2.new(1,0,0,24),
			Parent = executorFrame,
		})

		local runBtn = createSimple("TextButton", {
			BackgroundColor3 = Color3.fromRGB(0,120,60),
			BorderSizePixel = 0,
			Font = Enum.Font.SourceSansBold,
			Size = UDim2.new(0,60,1,0),
			Text = "Run",
			TextColor3 = Color3.new(1,1,1),
			TextSize = 14,
			Parent = btnBar,
		})

		local clearBtn = createSimple("TextButton", {
			BackgroundColor3 = Color3.fromRGB(60,60,60),
			BorderSizePixel = 0,
			Font = Enum.Font.SourceSans,
			Position = UDim2.new(0,64,0,0),
			Size = UDim2.new(0,60,1,0),
			Text = "Clear",
			TextColor3 = Color3.new(1,1,1),
			TextSize = 14,
			Parent = btnBar,
		})

		runBtn.MouseButton1Click:Connect(function()
			local src = codeFrame:GetText()
			local s, e = pcall(loadstring(src))
			if not s then
				addLog("error", tostring(e))
			end
		end)

		clearBtn.MouseButton1Click:Connect(function()
			codeFrame:SetText("")
		end)

		-- Console frame
		consoleFrame = createSimple("Frame", {
			BackgroundColor3 = Color3.fromRGB(20,20,20),
			BorderSizePixel = 0,
			Position = UDim2.new(0,0,0,20),
			Size = UDim2.new(1,0,1,-20),
			Visible = false,
			Parent = window.GuiElems.Content,
		})

		local consoleScroll = createSimple("ScrollingFrame", {
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Position = UDim2.new(0,0,0,0),
			Size = UDim2.new(1,0,1,-24),
			ScrollBarThickness = 4,
			CanvasSize = UDim2.new(0,0,0,0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			Parent = consoleFrame,
		})

		consoleList = createSimple("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1,0,0,0),
			AutomaticSize = Enum.AutomaticSize.Y,
			Parent = consoleScroll,
		})

		createSimple("UIListLayout", {
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0,2),
			Parent = consoleList,
		})

		local consoleBtnBar = createSimple("Frame", {
			BackgroundColor3 = Color3.fromRGB(25,25,25),
			BorderSizePixel = 0,
			Position = UDim2.new(0,0,1,-24),
			Size = UDim2.new(1,0,0,24),
			Parent = consoleFrame,
		})

		local clearConsoleBtn = createSimple("TextButton", {
			BackgroundColor3 = Color3.fromRGB(60,60,60),
			BorderSizePixel = 0,
			Font = Enum.Font.SourceSans,
			Size = UDim2.new(0,60,1,0),
			Text = "Clear",
			TextColor3 = Color3.new(1,1,1),
			TextSize = 14,
			Parent = consoleBtnBar,
		})

		clearConsoleBtn.MouseButton1Click:Connect(function()
			for _, v in pairs(consoleLogs) do v:Destroy() end
			consoleLogs = {}
		end)

		-- Tab switching
		local function showExecutor()
			executorFrame.Visible = true
			consoleFrame.Visible = false
			executorTabBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)
			executorTabBtn.TextColor3 = Color3.new(1,1,1)
			consoleTabBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
			consoleTabBtn.TextColor3 = Color3.fromRGB(180,180,180)
		end

		local function showConsole()
			executorFrame.Visible = false
			consoleFrame.Visible = true
			consoleTabBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)
			consoleTabBtn.TextColor3 = Color3.new(1,1,1)
			executorTabBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
			executorTabBtn.TextColor3 = Color3.fromRGB(180,180,180)
		end

		executorTabBtn.MouseButton1Click:Connect(showExecutor)
		consoleTabBtn.MouseButton1Click:Connect(showConsole)

		hookOutput()
		addLog("info", "Secret Service Panel ready.")
	end

	return SecretService
end

if gethsfuncs then
	_G.moduleData = {InitDeps = initDeps, InitAfterMain = initAfterMain, Main = main}
else
	return {InitDeps = initDeps, InitAfterMain = initAfterMain, Main = main}
end
